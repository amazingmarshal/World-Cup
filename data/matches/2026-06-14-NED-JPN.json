  "tacticalAnalysis": {
    "NED": {
      "summary": "Netherlands dominated possession (54.9%) and territory, creating more from open play but finishing poorly relative to chances. Buildup was patient and methodical through DE JONG and VAN DIJK, but Japan's deep block (50% low block) frustrated entry. Goals came from set-piece routines rather than open play dominance.",
      "strengths": [
        "Superior ball retention (529 passes, 89% completion) controlled game tempo",
        "Effective set-piece delivery — both goals came from crosses into the box",
        "DE JONG's ball recovery and midfield dominance limited Japan's transitions",
        "SUMMERVILLE's direct running created consistent half-chance situations"
      ],
      "weaknesses": [
        "Low xG (0.63) despite high possession suggests inability to break low block",
        "Three yellow cards (SUMMERVILLE, DEPAY, VAN DE VEN) indicate disciplinary fragility",
        "Defensive lapse late in match conceded equalizer from corner at 89'",
        "Failed to close out 2-1 lead with 25 minutes remaining"
      ]
    },
    "JPN": {
      "summary": "Japan executed a disciplined counter-pressing strategy (316 pressures vs NED's 194) while defending deep when needed (50% low block). Conceded early in second half but showed remarkable resilience, leveling twice — the second via a 89th-minute corner header from KAMADA. NAKAMURA was the primary attacking outlet.",
      "strengths": [
        "Elite work rate and pressing intensity — 316 total pressures, 46 direct",
        "Clinical counter-attacking through NAKAMURA and KAMADA when chances arose",
        "Defensive resilience and shape discipline held NED to 0.63 xG",
        "Substitute impact: OGAWA's corner assist led directly to KAMADA's equalizer"
