  "keyPlayers": {
    "GHA": [
      { "number": 3,  "name": "Caleb YIRENKYI",  "highlights": "Match-winner with 90+5' goal (right foot from cross). Team-high 12.6 km covered, 31/30 passes (97%), 6 direct pressures, 28 indirect. Relentless engine throughout — booked at 16' but never stopped running." },
      { "number": 4,  "name": "Jonas ADJETEY",   "highlights": "9 possession regains — most of any GHA player. 2 shots (47' header saved, 72' header off target), solid at right CB. Marshalled Ghana's defensive line under sustained Panama pressure." },
      { "number": 11, "name": "Antoine SEMENYO", "highlights": "Top speed 34.5 km/h — fastest on Ghana's team. 3 ball progressions, 3 aerial duels won. Constant threat on the counter despite only 24 passes. Won 3/3 tackles." }
    ],
