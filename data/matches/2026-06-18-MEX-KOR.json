  "tacticalAnalysis": {
    "MEX": {
      "summary": "Mexico set up in a compact 4-1-2-3, ceding possession deliberately and targeting transitions. Efficient finishing when chances came — Romo's winner from a loose ball in the box was the decisive moment.",
      "strengths": [
        "Disciplined defensive shape — mid/low block frustrated Korea's build-up",
        "Counter-attack speed through Alvarado and Vega on wide channels",
        "Alvarez as pivot — dominated pressing duels and dictated rhythm in defensive phase"
      ],
      "weaknesses": [
        "Low xG (0.34) — struggled to create high-quality chances from open play",
        "Pass accuracy dropped to 83% — loose in build-up under Korean press",
        "Limited aerial presence in defensive set pieces"
      ]
    },
    "KOR": {
      "summary": "Korea dominated possession (51.8%) and created better xG (0.87), but failed to convert. Mexico's low block absorbed pressure effectively and Korea ran out of ideas against a resolute defensive unit.",
      "strengths": [
        "Possession dominance — moved the ball well through Kangin and Hwang Inbeom",
        "Physical intensity — highest pressures applied and distance covered",
        "Late pressure — created 4 shots after the 80th minute but lacked clinical edge"
      ],
      "weaknesses": [
        "Only 2 shots on target from 9 attempts — quality of final ball poor",
        "Lost the key moment — failed to clear before Romo's goal",
        "Hwang Heechan and Cho Guesung couldn't change the game after coming on"
      ]
    }
