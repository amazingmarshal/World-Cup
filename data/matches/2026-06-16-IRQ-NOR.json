        "number": 18,
        "name": "AYMEN HUSSEIN",
        "highlights": "Iraq's lone goal-scorer at 39' with a header from a cross. Led the team with 59 offers made and 32 runs in-behind, causing problems for Norway's high line. Despite limited ball time (12 passes, 10 completed), his movement was Iraq's primary attacking threat."
      },
      {
        "number": 23,
        "name": "MERCHAS DOSKI",
        "highlights": "Most possession regains for Iraq (9) and most direct pressures on the team (15). Covered 10.5km and completed 11 of 17 line breaks (65%). The left-back was Iraq's most active pressing contributor throughout."
      },
      {
        "number": 16,
        "name": "AMIR ALAMMARI",
        "highlights": "Highest total distance covered on the team (11.2km) and most crosses attempted for Iraq (3). Key link player with 47 passes at 79% completion. 18 line break attempts — second most on the team — showed his willingness to drive forward."
      }
    ],
    "NOR": [
      {
        "number": 9,
        "name": "Erling HAALAND",
        "highlights": "Match-winner with 2 goals (29' and 43') and a further shot saved late on. Hit top speed of 36.5 km/h (fastest in the match). Only 8 passes but maximised every touch inside the box. 4 shots on target from 4 attempts. World-class finishing under pressure."
      },
      {
        "number": 8,
        "name": "Sander BERGE",
        "highlights": "Imperious in the pivot role — 80 passes with 98% completion rate (highest in match). 16 line break attempts, 15 completed (94%). 6 direct pressures led Norway's press. The fulcrum of Norway's dominance in possession."
      },
      {
        "number": 17,
        "name": "Torbjorn HEGGEM",
        "highlights": "Highest total passes for Norway (87 at 94% completion). 18 line breaks attempted, 15 completed. Covered 10.85km as the central pillar behind the midfield, constantly recycling possession and switching play with precision."
      },
      {
        "number": 4,
        "name": "Leo OSTIGARD",
        "highlights": "Impact sub — on at 73' and scored the crucial 4th goal at 76' from a corner header. Brought defensive solidity and winning mentality off the bench, aerially dominant in his short time on the pitch."
      }
